# instagram-mcp configuration. Copy to admin.env (chmod 600) or set in your
# MCP client's env block. Tokens are stored in the OS keychain by add_account;
# the env vars below are the zero-config single-account path.

# --- Single-account (zero-config) path ---------------------------------------
# A long-lived Instagram Graph API access token for an Instagram Business/Creator
# account. Get one via the Meta Graph API Explorer or your app's token flow.
INSTAGRAM_MCP_ACCESS_TOKEN=
# The Instagram Business Account id (numeric). Find via:
#   GET /me/accounts -> page id -> GET /{page-id}?fields=instagram_business_account
INSTAGRAM_MCP_IG_USER_ID=

# --- Optional ---------------------------------------------------------------
# Meta app secret. When set, every call is signed with appsecret_proof (hardening).
INSTAGRAM_MCP_APP_SECRET=
# Graph host: graph.facebook.com (default) or graph.instagram.com (IG-login tokens).
INSTAGRAM_MCP_BASE_HOST=graph.facebook.com
# Graph API version (default v21.0).
INSTAGRAM_MCP_GRAPH_VERSION=v21.0
# Set to 1 ONLY after Meta App Review grants instagram_manage_messages, to enable
# the DM tools (list_conversations / get_messages / send_message).
INSTAGRAM_MCP_DM_ENABLED=
# Override storage paths (defaults under ~/.claude/instagram-mcp/).
INSTAGRAM_MCP_ACCOUNTS_PATH=
INSTAGRAM_MCP_AUDIT_PATH=
# Per-call timeout in seconds (default 30).
INSTAGRAM_MCP_TIMEOUT=30
